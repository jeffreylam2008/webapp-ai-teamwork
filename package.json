{
  "name": "webapp-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 8000",
    "dev:optimized": "NODE_OPTIONS='--max-old-space-size=2048 --optimize-for-size' next dev --webpack -p 8000",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "build:production": "next build --webpack && npm run bundle:standalone",
    "bundle:standalone": "./scripts/bundle-standalone.sh",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "start:optimized": "NODE_OPTIONS='--max-old-space-size=2048' next start",
    "lint": "next lint",
    "clean": "rm -rf .next && rm -rf node_modules/.cache && npm cache clean --force",
    "update-browserslist": "npx update-browserslist-db@latest",
    "memory:optimize": "./scripts/optimize-memory.sh",
    "seed:items": "node scripts/seed-items-categories.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "antd": "^5.26.5",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "critters": "^0.0.25",
    "dayjs": "^1.11.13",
    "dotenv": "^17.3.1",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.2",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.17",
    "unix-crypt-td-js": "^1.1.4",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "browserslist": "^4.25.3",
    "caniuse-lite": "^1.0.30001797",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.6",
    "typescript": "^5"
  }
}
